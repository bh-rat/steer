{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "steer",
  "favicon": "/favicon.png",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "colors": {
    "primary": "#000000"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/bh-rat/steer"
      }
    ]
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": [
          "introduction",
          "quickstart"
        ]
      },
      {
        "group": "Components",
        "pages": [
          "components/secrets",
          "components/store",
          "components/context",
          "components/flow",
          "components/proc",
          "components/learn"
        ]
      },
      {
        "group": "Guides",
        "pages": [
          "guides/authoring"
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/bh-rat/steer"
    }
  },
  "search": {
    "prompt": "Search steer docs..."
  }
}
